{
  "builds": [
    { "src": "api/main.py", "use": "@vercel/python", "config": { "maxDuration": 60 } },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/main.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
